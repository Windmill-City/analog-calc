{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "analog-calc",
  "version": "1.0.0",
  "identifier": "com.tauri-app.analog-calc",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "模拟计算器",
        "width": 900,
        "height": 1000,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": {
      "linux": ["appimage"],
      "macOS": ["app"],
      "windows": []
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
